{
  "name": "gymchuot",
  "version": "0.1.0",
  "description": "Cổng giao tiếp bài tập giữa PT online và học viên",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "data:import": "node scripts/import-exercises.js",
    "data:translate": "ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY node scripts/translate-vi.js",
    "data:all": "npm run data:import && npm run data:translate",
    "db:reset": "npx supabase db reset"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.99.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^7.3.1"
  },
  "notes": {
    "data-pipeline": "Chạy 'npm run data:all' để pull 800+ bài tập từ free-exercise-db và dịch sang tiếng Việt. Cần ANTHROPIC_API_KEY cho bước dịch.",
    "production-stack": "Next.js + Supabase + dnd-kit (xem PLAN.md)"
  }
}
